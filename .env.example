# Jira PM Dashboard — Environment Variables
# Copy this to .env.local and fill in your values

# ─── Jira Integration ──────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_USER_EMAIL=yourname@company.com
JIRA_API_TOKEN=your_atlassian_api_token_here
# Optional. Leave empty to use built-in MDFM default JQL in code.
JIRA_JQL=

# ─── AI Provider (for summaries) ───────────────────────────────────────────────
# Optional: `openai` or `groq`. If omitted, app auto-detects by key prefix.
AI_PROVIDER=

# OpenAI config (sk-...)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Groq config (gsk-...)
GROQ_API_KEY=gsk-your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite database path (auto-created on first run)
DATABASE_PATH=./data/jira-dashboard.db

# ─── Demo Mode ──────────────────────────────────────────────────────────────────
# Set to "true" to use mock data without real Jira credentials
NEXT_PUBLIC_DEMO_MODE=false

# ─── Sync Settings ──────────────────────────────────────────────────────────────
# How often to auto-sync (in minutes, 0 = manual only)
SYNC_INTERVAL_MINUTES=30

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MDFM Analytics
